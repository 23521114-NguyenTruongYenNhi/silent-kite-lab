OPENAI_API_KEY=
# Alias accepted for the Docker requirement: docker run -e API_KEY=...
API_KEY=

# Optional: reuse existing resources instead of creating new ones.
OPENAI_VECTOR_STORE_ID=
OPENAI_ASSISTANT_ID=
OPENAI_MODEL=gpt-4.1-mini

# Scraper controls.
HELP_CENTER_BASE_URL=https://support.optisigns.com
HELP_CENTER_LOCALE=en-us
ARTICLE_LIMIT=50
REQUEST_TIMEOUT_SECONDS=30

# Upload controls.
UPLOAD_TO_OPENAI=true
FORCE_UPLOAD_ALL=false
CREATE_ASSISTANT_IF_MISSING=true
